source "https://rubygems.org"

# Modern Jekyll stack for local preview with newer Ruby versions.
# This intentionally does NOT use the "github-pages" gem, because that gem pins
# older Jekyll/Liquid versions and can cause compatibility issues on Ruby 3.2+ / 4.x.
gem "jekyll", "~> 4.4"

# Explicit compatibility gems for Windows and newer Ruby versions.
gem "webrick", ">= 1.8"
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "csv", ">= 3.3"
gem "bigdecimal", ">= 3.1"
gem "logger", ">= 1.6"
gem "base64", ">= 0.2"

gem "jekyll-seo-tag"
gem "jekyll-sitemap"
